  "capabilities": {
    "styles": true,
    "negativePrompt": false,
    "imageSize": false,
    "alchemy": false,
    "presetStyles": true,
    "tiling": false
  },

  "rules": [
    "DO NOT set negativePrompt — not available for this model.",
    "DO NOT set quality or mode — not available for this model.",
    "CRITICAL: width and height are validated INDEPENDENTLY. If both are valid values but do not form a supported pair, the API silently defaults to 1:1. Always use exact width+height from the aspectRatios table.",
    "10 aspect ratios × 3 sizes (1K, 2K, 4K) = 30 valid dimension combos.",
    "Default width/height is 1024x1024 (1:1 1K).",
    "Setting width=0 and height=0 = match input image reference (for img2img).",
    "style_ids: pick 1 style UUID that matches the prompt's mood/scene. Use None if no style fits.",
    "Must resolve style name to UUID — style_ids takes an array of UUIDs, not names.",
    "prompt_enhance defaults ON. Only set OFF if prompt is already highly detailed.",
    "quantity defaults 1. Use higher only if user explicitly requests multiple variants."
  ]
}
