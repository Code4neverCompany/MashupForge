{
  "modelId": "nano-banana-2",
  "apiName": "nano-banana-2",
  "type": "image",
  "endpoint": "POST /api/rest/v2/generations",

  "parameters": {
    "prompt": {
      "type": "string",
      "required": true,
      "description": "Text prompt describing what image to generate."
    },
    "model": {
      "type": "string",
      "required": true,
      "value": "nano-banana-2",
      "description": "Model identifier, always nano-banana-2."
    },
    "width": {
      "type": "integer",
      "required": false,
      "default": 1024,
      "description": "Image width. Must pair with a height from the supported dimension list. Set to 0 for img2img reference matching."
    },
    "height": {
      "type": "integer",
      "required": false,
      "default": 1024,
      "description": "Image height. Must pair with a width from the supported dimension list. Set to 0 for img2img reference matching."
    },
    "style_ids": {
      "type": "array",
      "required": false,
      "description": "Array of style UUIDs. Pick 1 style based on prompt mood/scene. Use None to disable styling."
    },
    "prompt_enhance": {
      "type": "string",
      "required": false,
      "allowedValues": ["ON", "OFF"],
      "default": "ON",
      "description": "Auto-enhance the prompt before generation."
    },
    "quantity": {
      "type": "integer",
      "required": false,
      "range": [1, 8],
      "default": 1,
      "description": "Number of images per request."
    },
    "seed": {
      "type": "integer",
      "required": false,
      "description": "Fixed seed for reproducible generations."
    },
    "public": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Whether the generation is publicly visible."
    },
    "guidances.image_reference": {
      "type": "array",
      "required": false,
      "maxItems": 6,
      "description": "Reference images to guide generation.",
      "itemSchema": {
        "image.id": "string — Leonardo image ID",
        "image.type": "GENERATED | UPLOADED",
        "strength": "LOW | MID | HIGH"
      }
    }
  },

  "styles": {
