{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MashupForge",
  "version": "0.1.0",
  "identifier": "com.4nevercompany.mashupforge",
  "build": {
    "frontendDist": "../src-tauri/frontend-stub",
    "devUrl": "http://localhost:3100",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MashupForge",
        "url": "index.html",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
