# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# LEONARDO_API_KEY: Required for Leonardo.AI image generation.
LEONARDO_API_KEY="MY_LEONARDO_API_KEY"

# ── SCHED-POST-ROBUST: server-side cron queue ─────────────────────────────
# Required when serverCronEnabled=true in user settings (i.e., when the
# GitHub Actions cron at .github/workflows/cron-fire-scheduled-posts.yml
# is the owner of scheduled-post firing instead of the open-tab browser).

# Upstash Redis REST endpoint + token. Provision a free DB at
# https://console.upstash.com/redis and copy the REST URL + token from
# the database dashboard.
UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<your-rest-token>"

# Shared secret for the cron-fire endpoint. Must match the same value
# stored as a GitHub Actions secret. Generate with:
#   openssl rand -hex 32
CRON_SHARED_SECRET="<32-byte-hex-string>"

# ── Instagram Graph API (server-side post execution) ──────────────────────
# Required for the cron-fire path to publish IG posts without an open
# browser. Long-lived Facebook Page Token (must start with EAA — IGAA/IGQ
# Basic Display tokens are rejected at app/api/social/post/route.ts).
# Generate via: https://developers.facebook.com/tools/explorer
INSTAGRAM_ACCESS_TOKEN="EAA<your-long-lived-page-token>"

# Instagram business account ID (numeric). Find via Graph API Explorer:
#   GET /me/accounts → page id → GET /<page-id>?fields=instagram_business_account
INSTAGRAM_ACCOUNT_ID="<numeric-ig-business-account-id>"
